# DocFlow AI — Environment Variables
# Copy this file to .env and fill in your values.
# Lines marked [REQUIRED] must be set for the app to start.
# Lines marked [OPTIONAL] have defaults or can be left empty.

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string.
# Free tiers: Supabase (https://supabase.com) or Neon (https://neon.tech)
# Local: postgresql://docflow:docflow@localhost:5432/docflow
DATABASE_URL=postgresql://docflow:docflow@localhost:5432/docflow

# ─────────────────────────────────────────────────────────────────────────────
# REDIS / QUEUE
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Redis connection URL for BullMQ.
# Free tier: Upstash (https://upstash.com) — use the redis:// URL format.
# Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDER — select one
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Which AI provider to use: groq | gemini | ollama
# Falls back to deterministic template generation if any provider is unavailable.
AI_PROVIDER=groq

# [REQUIRED for groq] Get your free API key at https://console.groq.com
# Free tier: ~14,400 tokens/min with llama-3.3-70b-versatile
GROQ_API_KEY=

# [OPTIONAL for groq] Model to use (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# [REQUIRED for gemini] Get your free API key at https://aistudio.google.com
GEMINI_API_KEY=

# [OPTIONAL for gemini] Model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# [REQUIRED for ollama] Base URL of your Ollama instance
OLLAMA_BASE_URL=http://localhost:11434
# [OPTIONAL for ollama] Model to use
OLLAMA_MODEL=qwen2.5-coder:7b

# ─────────────────────────────────────────────────────────────────────────────
# GITHUB APP
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Create a GitHub App at https://github.com/settings/apps/new
# See docs/GITHUB_APP_SETUP.md for step-by-step instructions.
GITHUB_APP_ID=
GITHUB_APP_NAME=docflow-ai

# [REQUIRED] Download the private key from your GitHub App settings.
# For .env: paste the entire PEM content, replacing newlines with \n
# e.g. -----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----
GITHUB_PRIVATE_KEY=

# [REQUIRED] Set in your GitHub App webhook configuration
# Generate a strong random secret: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# [REQUIRED] GitHub OAuth App credentials (used by NextAuth.js)
# Create at https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Random secret for JWT signing: openssl rand -base64 32
NEXTAUTH_SECRET=

# [REQUIRED] Public URL of your frontend (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# SERVICE URLS (internal)
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Backend API base URL (default: http://localhost:4000)
NEXT_PUBLIC_API_URL=http://localhost:4000

# [OPTIONAL] GitHub webhook receiver URL (for Probot)
# Local dev: use smee.io — npx smee-client --url <smee-url> --target http://localhost:4001
WEBHOOK_PROXY_URL=

# [OPTIONAL] Port for the backend API server (default: 4000)
PORT=4000

# [OPTIONAL] Port for the GitHub webhook receiver (default: 4001)
WEBHOOK_PORT=4001
