{
  "name": "docflow-ai",
  "version": "1.0.0",
  "private": true,
  "description": "DocFlow AI — Automated Repository Documentation & Intelligence Platform",
  "scripts": {
    "predev": "turbo run build --filter=!@docflow/web",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:generate": "pnpm -F @docflow/database db:generate",
    "db:migrate": "pnpm -F @docflow/database db:migrate",
    "db:migrate:dev": "pnpm -F @docflow/database db:migrate:dev",
    "db:studio": "pnpm -F @docflow/database db:studio",
    "clean": "turbo run clean && rimraf node_modules",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "turbo": "^2.0.9",
    "typescript": "^5.5.2",
    "eslint": "^9.6.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
