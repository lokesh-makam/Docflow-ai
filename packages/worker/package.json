    "@docflow/parser": "workspace:*",
    "@docflow/queue": "workspace:*",
    "@docflow/shared": "workspace:*",
    "mdast-util-from-markdown": "^2.0.1",
    "mdast-util-to-markdown": "^2.1.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.2"
  }
