// DocFlow AI — Database Schema
// Production-grade relational design

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model User {
  id           String       @id @default(cuid())
  githubId     Int          @unique
  username     String
  displayName  String?
  avatarUrl    String?
  email        String?
  accessToken  String       // AES-256-GCM encrypted GitHub OAuth token
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  repositories Repository[]

  @@map("users")
}

model Repository {
  id            String   @id @default(cuid())
  githubRepoId  Int      @unique
  fullName      String   // "owner/repo"
  name          String   @default("")
  owner         String   @default("")
  defaultBranch String   @default("main")
  trackedBranch String   @default("main")
  isPrivate     Boolean  @default(false)
  language      String?
  description   String?
  stars         Int      @default(0)
  docStyle      String   @default("standard")
  aiProvider    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobs        AnalysisJob[]
  cachedFacts CachedFacts?
  draft       ReadmeDraft?

  @@index([userId])
  @@map("repositories")
}

model AnalysisJob {
  id           String    @id @default(cuid())
  status       JobStatus @default(PENDING)
  commitSha    String
  branch       String
  errorMessage String?
  usedFallback Boolean   @default(false)
  sectionsCount Int?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
  @@map("analysis_jobs")
}

model CachedFacts {
  id              String   @id @default(cuid())
  factJson        Json     // Structured RepoFacts (no raw source code)
  generatedReadme String?  // Full generated README markdown for fast retrieval
  commitSha       String
  updatedAt       DateTime @updatedAt

  repositoryId String     @unique
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("cached_facts")
}

model ReadmeDraft {
  id        String   @id @default(cuid())
  content   String   // Current working draft
  updatedAt DateTime @updatedAt

  repositoryId String     @unique
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("readme_drafts")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum JobStatus {
  PENDING
  ACTIVE
  COMPLETED
  FAILED
}
